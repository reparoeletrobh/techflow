.ckbody{display:grid;grid-template-columns:1fr 1fr;gap:0}
@media(max-width:620px){.ckbody{grid-template-columns:1fr}}
.ckphotos{position:relative;aspect-ratio:1;background:var(--bg3);overflow:hidden}
.ckphotos img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .3s}
.ckphotos img.on{opacity:1}
.ckthumbs{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);display:flex;gap:5px}
.ckthumb{width:42px;height:42px;border-radius:6px;overflow:hidden;cursor:pointer;border:2px solid transparent;transition:border-color .2s;flex-shrink:0}
.ckthumb.on{border-color:var(--gold)}
.ckthumb img{width:100%;height:100%;object-fit:cover}
.ckexpand{position:absolute;top:9px;right:9px;background:rgba(0,0,0,.6);border:1px solid rgba(255,255,255,.14);border-radius:7px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.ckexpand svg{width:15px;height:15px;fill:white}
.ckinfo{padding:28px 26px;display:flex;flex-direction:column}
.ckos{font-family:var(--fm);font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:6px}
.ckname{font-family:var(--fh);font-size:24px;font-weight:900;margin-bottom:4px}
.ckspecs{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:18px}
.ckspec{font-size:12px;background:var(--bg3);color:var(--muted2);padding:4px 11px;border-radius:7px}
.ckdlbl{font-family:var(--fm);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:7px}
.ckdesc{font-size:13px;color:var(--muted2);line-height:1.7;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid rgba(201,178,152,.08)}
.ckprow{display:flex;align-items:baseline;gap:10px;margin-bottom:6px}
.ckold{font-size:13px;color:var(--muted);text-decoration:line-through}
.ckprice{font-family:var(--fh);font-size:34px;font-weight:900;color:var(--green);line-height:1}
.ckpsub{font-size:12px;color:var(--muted2);margin-bottom:24px}
.ckinput{width:100%;background:var(--bg3);border:1px solid rgba(201,178,152,.12);border-radius:10px;padding:12px 15px;font-family:var(--fb);font-size:14px;color:var(--text);margin-bottom:10px;outline:none;transition:border-color .2s}
.ckinput::placeholder{color:var(--muted)}
.ckinput:focus{border-color:rgba(201,178,152,.38)}
.cksubmit{width:100%;padding:15px;background:var(--gold);color:var(--bg);font-family:var(--fb);font-size:15px;font-weight:700;border:none;border-radius:12px;cursor:pointer;transition:all .2s;margin-top:2px}
.cksubmit:hover{background:#d4bc8a;transform:translateY(-1px);box-shadow:0 12px 28px rgba(201,178,152,.24)}
.cksec{text-align:center;font-size:11px;color:var(--muted);margin-top:10px;display:flex;align-items:center;justify-content:center;gap:5px}
/* FOOTER */
.footer{padding:56px 40px 36px;text-align:center;border-top:1px solid rgba(201,178,152,.08)}
.flogo{font-family:var(--fh);font-size:21px;font-weight:900;margin-bottom:7px}
.flogo span{color:var(--gold)}
.fsub{font-size:13px;color:var(--muted)}
/* AB BADGE */
.abbadge{position:fixed;bottom:18px;left:18px;font-family:var(--fm);font-size:9px;letter-spacing:2px;text-transform:uppercase;padding:5px 11px;border-radius:6px;z-index:200;opacity:.55}
.ab-a{background:rgba(59,130,246,.13);color:#93c5fd;border:1px solid rgba(59,130,246,.28)}
.ab-b{background:rgba(201,178,152,.09);color:var(--gold);border:1px solid rgba(201,178,152,.28)}
/* SCROLL FADE */
.fi{opacity:0;transform:translateY(22px);transition:opacity .7s,transform .7s}
.fi.vis{opacity:1;transform:none}
#catalogo{scroll-margin-top:80px}
@media(max-width:768px){.nav{padding:14px 18px}.hero{padding:96px 18px 56px}.catalog{padding:56px 16px}.pgrid{grid-template-columns:1fr}}
</style>
</head>
