  const list = f==='all'?PROD:PROD.filter(p=>p.cat===f);
  g.innerHTML = list.map((p,i)=>`
    <div class="pcard fi" style="transition-delay:${i*.06}s">
      <div class="cphoto" id="cp-${p.id}">
        ${p.fotos.map((f,j)=>`<img src="${f}" alt="${p.nome}" class="${j===0?'on':''}" loading="lazy">`).join('')}
        <div class="cphoto-nav">
          <div class="cnav" onclick="slide('${p.id}',-1,event)"><svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg></div>
          <div class="cnav" onclick="slide('${p.id}',1,event)"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></div>
        </div>
        <div class="cexpand" onclick="lbOpen('${p.id}',event)"><svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg></div>
        <div class="cbadge">✓ Revisado</div>
        <div class="cdots" id="dots-${p.id}">
