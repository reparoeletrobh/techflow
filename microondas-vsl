// ── A/B TEST ──────────────────────────────────────────────────────────────
const AB = (Math.random() < 0.5) ? 'A' : 'B';
// Forçar versão: AB = 'A' (WhatsApp) | AB = 'B' (Checkout)
const badge = document.getElementById('abbadge');
badge.textContent = 'A/B — Versão ' + AB;
badge.className = 'abbadge ' + (AB==='A'?'ab-a':'ab-b');

const WA = '5531999999999'; // ← NÚMERO REAL AQUI
const waMsg = (n,id,p) => encodeURIComponent('Olá! Tenho interesse no *'+n+'* ('+id+') por '+p+'. Ainda disponível?');
const R = n => 'R$ ' + Number(n).toFixed(2).replace('.',',').replace(/\B(?=(\d{3})+(?!\d))/g,'.');

// ── PRODUTOS ──────────────────────────────────────────────────────────────
// Conectar à API real: fetch('/api/tv-equipamentos?action=load').then(r=>r.json()).then(d=>{...})
const PROD = [
  {id:'MI-7991',nome:'ELECTROLUX mt30s',cat:'microondas',lit:'20 litros',ten:'127v',p:270,po:650,
