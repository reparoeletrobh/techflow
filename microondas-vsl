hr{border:none;height:1px;background:linear-gradient(to right,transparent,rgba(201,178,152,.2),transparent);margin:0 40px}
/* CATALOG */
.catalog{padding:90px 24px;max-width:1200px;margin:0 auto}
.sec-tag{font-family:var(--fm);font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:flex;align-items:center;gap:10px}
.sec-tag::before{content:'';height:1px;width:28px;background:var(--gold);opacity:.5}
.sec-title{font-family:var(--fh);font-size:clamp(30px,4vw,50px);font-weight:900;line-height:1.1;margin-bottom:10px}
.sec-title em{font-style:italic;color:var(--gold)}
.sec-sub{color:var(--muted2);font-size:15px;margin-bottom:52px;max-width:500px}
.filters{display:flex;gap:9px;flex-wrap:wrap;margin-bottom:44px}
.fpill{font-family:var(--fm);font-size:11px;letter-spacing:1.5px;text-transform:uppercase;padding:8px 18px;border-radius:99px;border:1px solid rgba(201,178,152,.2);color:var(--muted2);cursor:pointer;transition:all .2s;background:transparent}
.fpill.active,.fpill:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,178,152,.06)}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:22px}
