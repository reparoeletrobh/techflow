.cbadge{position:absolute;top:9px;left:9px;font-family:var(--fm);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;padding:4px 9px;border-radius:6px;background:rgba(16,185,129,.14);color:var(--green);border:1px solid rgba(16,185,129,.28)}
.cbody{padding:18px 18px 22px}
