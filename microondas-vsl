.ckoverlay{display:none;position:fixed;inset:0;z-index:900;background:rgba(0,0,0,.88);align-items:center;justify-content:center;padding:18px}
.ckoverlay.open{display:flex}
.ckmodal{background:var(--bg2);border:1px solid rgba(201,178,152,.14);border-radius:20px;width:100%;max-width:840px;max-height:90vh;overflow-y:auto;position:relative}
.ckhead{position:sticky;top:0;z-index:10;display:flex;align-items:center;justify-content:space-between;padding:18px 26px;background:var(--bg2);border-bottom:1px solid rgba(201,178,152,.1)}
.ckhead-title{font-family:var(--fh);font-size:17px;font-weight:700}
.ckxbtn{width:34px;height:34px;background:var(--bg3);border:1px solid rgba(255,255,255,.08);border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px;color:var(--muted2);transition:background .2s}
