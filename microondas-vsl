.cname{font-family:var(--fh);font-size:19px;font-weight:700;margin-bottom:6px}
.cspecs{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px}
.cspec{font-size:11px;color:var(--muted2);background:var(--bg3);padding:4px 9px;border-radius:6px}
.cdesc{font-size:13px;color:var(--muted2);line-height:1.5;margin-bottom:18px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.cfooter{display:flex;align-items:center;justify-content:space-between;gap:10px}
.cprice{display:flex;flex-direction:column}
.cold{font-size:12px;color:var(--muted);text-decoration:line-through}
.cnow{font-family:var(--fh);font-size:23px;font-weight:700;color:var(--green);line-height:1}
