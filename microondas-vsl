// SLIDER
function getIdx(id){return pIdx[id]||0}
function setIdx(id,i){
  const w=document.getElementById('cp-'+id); if(!w)return;
  const imgs=w.querySelectorAll('img'), dots=document.getElementById('dots-'+id)?.querySelectorAll('.cdot');
  const n=imgs.length; i=((i%n)+n)%n; pIdx[id]=i;
  imgs.forEach((el,j)=>el.classList.toggle('on',j===i));
  dots&&dots.forEach((d,j)=>d.classList.toggle('on',j===i));
}
function slide(id,d,e){e?.stopPropagation();setIdx(id,getIdx(id)+d)}
function gp(id,i,e){e?.stopPropagation();setIdx(id,i)}

// LIGHTBOX
let lbImgs=[],lbI=0;
function lbOpen(id,e){e?.stopPropagation();const p=PROD.find(x=>x.id===id);if(!p)return;lbImgs=p.fotos;lbI=getIdx(id);lbShow();document.getElementById('lb').classList.add('open')}
function lbShow(){document.getElementById('lb-img').src=lbImgs[lbI];document.getElementById('lb-count').textContent=(lbI+1)+' / '+lbImgs.length}
function lbPrev(){lbI=((lbI-1)+lbImgs.length)%lbImgs.length;lbShow()}
function lbNext(){lbI=(lbI+1)%lbImgs.length;lbShow()}
function lbClose(){document.getElementById('lb').classList.remove('open')}
document.getElementById('lb').addEventListener('click',function(e){if(e.target===this)lbClose()})

// CHECKOUT
let ckP=null, ckPI=0;
function ckOpen(id){
  const p=PROD.find(x=>x.id===id); if(!p)return; ckP=p; ckPI=0;
  document.getElementById('ck-title').textContent='Finalizar — '+p.nome;
  document.getElementById('ck-os').textContent=p.id;
  document.getElementById('ck-name').textContent=p.nome;
  document.getElementById('ck-desc').textContent=p.desc;
  document.getElementById('ck-price').textContent=R(p.p);
  document.getElementById('ck-old').textContent=R(p.po);
  document.getElementById('ck-specs').innerHTML=`<span class="ckspec">⚡ ${p.ten}</span><span class="ckspec">📐 ${p.lit}</span><span class="ckspec">✓ Revisado</span>`;
  const ph=document.getElementById('ck-photos');
  ph.querySelectorAll('img').forEach(el=>el.remove());
  p.fotos.forEach((f,j)=>{const img=document.createElement('img');img.src=f;img.alt=p.nome;if(j===0)img.classList.add('on');ph.insertBefore(img,ph.firstChild)});
  document.getElementById('ck-thumbs').innerHTML=p.fotos.map((f,j)=>`<div class="ckthumb ${j===0?'on':''}" onclick="ckGP(${j})"><img src="${f}" alt=""></div>`).join('');
  document.getElementById('ckoverlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function ckGP(i){if(!ckP)return;ckPI=i;const ph=document.getElementById('ck-photos');ph.querySelectorAll('img').forEach((el,j)=>el.classList.toggle('on',j===i));document.getElementById('ck-thumbs').querySelectorAll('.ckthumb').forEach((t,j)=>t.classList.toggle('on',j===i))}
function ckExpandPhoto(){if(!ckP)return;lbImgs=ckP.fotos;lbI=ckPI;lbShow();document.getElementById('lb').classList.add('open')}
function ckClose(){document.getElementById('ckoverlay').classList.remove('open');document.body.style.overflow=''}
document.getElementById('ckoverlay').addEventListener('click',function(e){if(e.target===this)ckClose()})
function ckSubmit(){
  const nome=document.getElementById('ck-nome').value.trim(), tel=document.getElementById('ck-tel').value.trim();
  if(!nome||!tel){alert('Preencha seu nome e WhatsApp.');return}
  const msg='Olá! Quero confirmar o pedido:\n\n*'+ckP.nome+'* ('+ckP.id+')\nPreço: '+R(ckP.p)+'\n\nNome: '+nome+'\nTelefone: '+tel;
  window.open('https://wa.me/'+WA+'?text='+encodeURIComponent(msg),'_blank');
  ckClose();
}

// FILTERS
document.querySelectorAll('.fpill').forEach(el=>{
  el.addEventListener('click',function(){
    document.querySelectorAll('.fpill').forEach(p=>p.classList.remove('active'));
    this.classList.add('active');
    render(this.dataset.f);
  });
});

// KEYBOARD
document.addEventListener('keydown',e=>{
  if(document.getElementById('lb').classList.contains('open')){
    if(e.key==='ArrowLeft')lbPrev();
    if(e.key==='ArrowRight')lbNext();
    if(e.key==='Escape')lbClose();
  }
  if(document.getElementById('ckoverlay').classList.contains('open')&&e.key==='Escape')ckClose();
});

// FADE IN OBSERVER
function observe(){
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');io.unobserve(e.target)}})
  },{threshold:.08});
  document.querySelectorAll('.fi:not(.vis)').forEach(el=>io.observe(el));
}

// ANALYTICS
function track(type,id){console.log('[A/B]',AB,type,id);/* integrar GTM/Meta Pixel aqui */}

// INIT
render('all');
observe();
</script>
