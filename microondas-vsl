.cnav svg{width:13px;height:13px;fill:white}
.cdots{position:absolute;bottom:9px;left:50%;transform:translateX(-50%);display:flex;gap:4px}
.cdot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,.3);transition:all .2s}
.cdot.on{background:var(--gold);width:14px;border-radius:3px}
.cexpand{position:absolute;top:9px;right:9px;width:28px;height:28px;background:rgba(0,0,0,.6);border:1px solid rgba(255,255,255,.13);border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;transition:opacity .2s,background .2s}
